{
  "name": "risu",
  "version": "0.1.0",
  "description": "Менеджер подписок и регулярных платежей на Angular 21 + Taiga UI",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration=production",
    "build:gh-pages": "ng build --configuration=production --base-href=/Risu/",
    "postbuild:gh-pages": "node scripts/spa-fallback.mjs",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false",
    "test:watch": "ng test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint \"src/**/*.{ts,html}\" \"e2e/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.{ts,html}\" \"e2e/**/*.ts\" --fix",
    "lint:styles": "stylelint \"src/**/*.{scss,css}\"",
    "lint:styles:fix": "stylelint \"src/**/*.{scss,css}\" --fix",
    "format": "prettier --write \"src/**/*.{ts,html,scss,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss,json}\""
  },
  "private": true,
  "packageManager": "npm@10.9.3",
  "dependencies": {
    "@angular/animations": "^21.2.10",
    "@angular/cdk": "^21.2.8",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@maskito/angular": "^5.2.2",
    "@maskito/core": "^5.2.2",
    "@maskito/kit": "^5.2.2",
    "@maskito/phone": "^5.2.2",
    "@ng-web-apis/common": "^5.2.0",
    "@ng-web-apis/intersection-observer": "^5.2.0",
    "@ng-web-apis/mutation-observer": "^5.2.0",
    "@ng-web-apis/platform": "^5.2.0",
    "@ng-web-apis/resize-observer": "^5.2.0",
    "@ng-web-apis/screen-orientation": "^5.2.0",
    "@ngrx/signals": "^21.1.0",
    "@taiga-ui/cdk": "^5.4.0",
    "@taiga-ui/core": "^5.4.0",
    "@taiga-ui/design-tokens": "^0.293.0",
    "@taiga-ui/event-plugins": "^5.0.0",
    "@taiga-ui/font-watcher": "^0.6.0",
    "@taiga-ui/i18n": "^5.4.0",
    "@taiga-ui/icons": "^5.4.0",
    "@taiga-ui/kit": "^5.4.0",
    "@taiga-ui/polymorpheus": "^5.0.0",
    "@taiga-ui/styles": "^5.4.0",
    "@tinkoff/ng-dompurify": "^4.0.0",
    "libphonenumber-js": "^1.12.42",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^21.0.0",
    "@angular-eslint/eslint-plugin": "^21.0.0",
    "@angular-eslint/eslint-plugin-template": "^21.0.0",
    "@angular-eslint/template-parser": "^21.0.0",
    "@angular/build": "^21.1.5",
    "@angular/cli": "^21.1.5",
    "@angular/compiler-cli": "^21.1.0",
    "@playwright/test": "^1.49.0",
    "@types/node": "^25.6.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "jsdom": "^27.1.0",
    "less": "^4.6.4",
    "less-loader": "^12.3.2",
    "prettier": "^3.4.2",
    "stylelint": "^16.13.2",
    "stylelint-config-standard-scss": "^14.0.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.20.0",
    "vitest": "^4.0.8"
  }
}
